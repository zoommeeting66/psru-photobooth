# Copy to .env and adjust. Defaults run with SQLite (no external services needed).
APP_NAME="PSRU AI Virtual Photo Booth API"
ENV=dev

# Database — SQLite for local dev, or PostgreSQL for prod:
#   postgresql+asyncpg://psru:psru@localhost:5432/photobooth
DATABASE_URL=sqlite+aiosqlite:///./data/photobooth.db

# Where uploaded captures / generated outputs are stored (local FS in dev; S3/R2 in prod)
STORAGE_DIR=./data/storage
PUBLIC_BASE_URL=http://localhost:8000

# Auth — dev mode (HS256). Used when OIDC is not configured + for /auth/dev-token.
JWT_SECRET=dev-insecure-secret-change-me
JWT_ALG=HS256
AUTH_DEV_MODE=true

# Auth — production (OIDC / Keycloak). Set OIDC_ISSUER to enable JWKS validation.
#   OIDC_ISSUER=http://localhost:8080/realms/psru
#   OIDC_AUDIENCE=account
OIDC_ISSUER=
OIDC_AUDIENCE=account

# AI pipeline. MOCK=true simulates render stages without a GPU (Phase 1 default).
PIPELINE_MOCK=true
PIPELINE_STAGE_DELAY_MS=400

# PDPA retention (hours)
CAPTURE_TTL_HOURS=24
OUTPUT_TTL_DAYS=30
POLICY_VERSION=2026.1
