{
  "realm": "psru",
  "enabled": true,
  "displayName": "PSRU Photo Booth",
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "admin", "description": "ผู้ดูแลระบบ" },
      { "name": "operator", "description": "เจ้าหน้าที่บูธ" },
      { "name": "executive", "description": "ผู้บริหาร (ดู dashboard)" },
      { "name": "user", "description": "ผู้ใช้ทั่วไป" }
    ]
  },
  "clients": [
    {
      "clientId": "photobooth-spa",
