    {
      "username": "operator",
      "enabled": true,
      "email": "operator@psru.ac.th",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "operator", "temporary": false }],
      "realmRoles": ["operator"]
    },
    {
      "username": "executive",
      "enabled": true,
      "email": "executive@psru.ac.th",
      "emailVerified": true,
